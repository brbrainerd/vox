# Vox Environment Variables
# Copy this file to .env and fill in your values.
# Run `vox doctor` to verify your setup.

# ── AI Provider Keys ──────────────────────────────────────────────────────────

# Google AI Studio (FREE — no credit card required)
# Get your key at: https://aistudio.google.com/apikey (just needs a Google account)
# Provides: Gemini 2.5 Flash-Lite, Flash, Pro — all free with generous rate limits
GEMINI_API_KEY=

# OpenRouter (OPTIONAL — free key unlocks :free models; paid key enables SOTA)
# Get your key at: https://openrouter.ai/keys
# Free models: Devstral 2, Qwen3 Coder, Llama 4 Scout, Kimi K2, and more
# Paid models: DeepSeek v3.2, Claude Sonnet 4.5, GPT-5, O3
OPENROUTER_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

# Turso remote database (OPTIONAL — defaults to local SQLite at ~/.vox/vox.db)
# Required only for multi-device sync or production deployments
# Get a free database at: https://turso.tech/
VOX_DB_URL=
VOX_DB_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────

# Port for the Vox MCP server (default: 3000)
PORT=3000
